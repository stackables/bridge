{
  "name": "@stackables/bridge-core",
  "version": "1.0.2",
  "description": "Bridge runtime engine — execute pre-compiled bridge instructions",
  "main": "./build/index.js",
  "type": "module",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "lint:types": "tsc -p tsconfig.check.json",
    "test": "node --experimental-transform-types --conditions source --test test/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info --experimental-transform-types --conditions source --test test/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackables/bridge.git"
  },
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@stackables/bridge-stdlib": "workspace:*",
    "@stackables/bridge-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
