{
  "name": "@stackables/bridge-core",
  "version": "1.7.0",
  "description": "Bridge runtime engine — execute pre-compiled bridge instructions",
  "main": "./src/index.ts",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "lint:types": "tsc -p tsconfig.json",
    "dump": "node dump-tree.mjs | pbcopy && echo 'ExecutionTree source copied to clipboard'",
    "test": "node --experimental-transform-types --test test/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info --experimental-transform-types --test test/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackables/bridge.git"
  },
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@stackables/bridge-stdlib": "workspace:*",
    "@stackables/bridge-types": "workspace:*"
  },
  "devDependencies": {
    "@stackables/bridge-graphql": "workspace:*",
    "@stackables/bridge-parser": "workspace:*",
    "@types/node": "^25.5.0",
    "graphql": "16.13.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "main": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    }
  }
}
