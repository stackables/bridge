{
  "name": "@stackables/bridge-parser",
  "version": "1.4.3",
  "description": "Bridge DSL parser — turns .bridge text into a BridgeDocument (AST)",
  "main": "./src/index.ts",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint:types": "tsc -p tsconfig.json",
    "test": "node --experimental-transform-types --test test/*.test.ts",
    "fuzz": "node --experimental-transform-types --test test/*.fuzz.ts",
    "prepack": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackables/bridge.git"
  },
  "license": "MIT",
  "dependencies": {
    "@stackables/bridge-core": "workspace:*",
    "@stackables/bridge-stdlib": "workspace:*",
    "chevrotain": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "fast-check": "^4.5.3",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public",
    "main": "./build/index.js",
    "types": "./build/index.d.ts",
    "exports": {
      ".": {
        "types": "./build/index.d.ts",
        "default": "./build/index.js"
      }
    }
  }
}
