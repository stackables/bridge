  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackables/bridge.git"
  },
  "license": "MIT",
  "dependencies": {
    "@stackables/bridge-types": "workspace:*",
    "lru-cache": "^11.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
