{
  "name": "@stackables/bridge-stdlib",
  "version": "0.0.1",
  "description": "Bridge standard library — httpCall, string, array, audit, and assert tools",
  "main": "./build/index.js",
  "type": "module",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
