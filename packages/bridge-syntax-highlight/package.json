{
  "name": "bridge-syntax-highlight",
  "displayName": "The Bridge Language",
  "description": "Syntax highlighting, real-time diagnostics, and hover information for the Bridge declarative dataflow language",
  "version": "1.2.1",
  "publisher": "stackables",
  "icon": "logo128.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackables/bridge.git"
  },
  "main": "./build/extension.js",
  "activationEvents": [
    "onLanguage:bridge"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bridge",
        "aliases": [
          "The Bridge",
          "bridge"
        ],
        "extensions": [
          ".bridge"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bridge",
        "scopeName": "source.bridge",
        "path": "./syntaxes/bridge.tmLanguage.json"
      },
      {
        "scopeName": "inline.bridge",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ],
        "path": "./syntaxes/bridge.inline.json",
        "embeddedLanguages": {
          "source.bridge": "bridge"
        }
      }
    ],
    "configurationDefaults": {
      "[bridge]": {
        "editor.defaultFormatter": "stackables.bridge-syntax-highlight"
      }
    }
  },
  "scripts": {
    "prebuild": "pnpm --recursive --filter '@stackables/*' --filter '!@stackables/bridge-playground' build",
    "build": "node build.mjs",
    "lint:types": "tsc -p tsconfig.json",
    "watch": "node build.mjs --watch",
    "prevscode:prepublish": "pnpm --recursive --filter '@stackables/*' --filter '!@stackables/bridge-playground' build",
    "vscode:prepublish": "node build.mjs"
  },
  "devDependencies": {
    "@stackables/bridge": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
