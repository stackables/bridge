{
  "name": "@stackables/bridge",
  "version": "1.22.1",
  "description": "Declarative dataflow for GraphQL",
  "main": "./build/index.js",
  "type": "module",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "lint:types": "tsc -p tsconfig.check.json",
    "test": "node --experimental-transform-types --conditions source --test test/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackables/bridge.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/stackables/bridge/issues"
  },
  "homepage": "https://github.com/stackables/bridge#readme",
  "devDependencies": {
    "@graphql-tools/executor-http": "^3.1.0",
    "@types/node": "^25.3.2",
    "graphql": "^16.13.0",
    "graphql-yoga": "^5.18.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@stackables/bridge-compiler": "workspace:*",
    "@stackables/bridge-core": "workspace:*",
    "@stackables/bridge-graphql": "workspace:*",
    "@stackables/bridge-stdlib": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b"
}
