---
// Playground page — uses the Starlight header; the playground fills the space below it.
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import PlaygroundWrapper from "../components/PlaygroundWrapper";
---

<StarlightPage frontmatter={{ title: 'Playground · Bridge', template: 'splash' }}>
  <div class="not-content" style="margin: calc(-1 * var(--sl-content-pad-y, 1.5rem)) calc(-1 * var(--sl-content-pad-x, 1rem))">
    <PlaygroundWrapper client:only="react" />
  </div>
</StarlightPage>
