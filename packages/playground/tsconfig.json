{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@stackables/bridge": ["../bridge/src/index.ts"],
      "@stackables/bridge-core": ["../bridge-core/src/index.ts"],
      "@stackables/bridge-parser": ["../bridge-parser/src/index.ts"],
      "@stackables/bridge-graphql": ["../bridge-graphql/src/index.ts"],
      "@stackables/bridge-stdlib": ["../bridge-stdlib/src/index.ts"]
    }
  },
  "include": ["src", "test", "vite.config.ts"]
}
