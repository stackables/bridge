+function getPnpmWorkspaceManifest() {
+  const workingDirectory = cwd();
+  // Walk up to find the workspace root (where pnpm-workspace.yaml lives)
+  let rootDir = workingDirectory;
+  while (rootDir !== dirname(rootDir)) {
+    if (existsSync(join(rootDir, "pnpm-workspace.yaml"))) break;
+    rootDir = dirname(rootDir);
+  }
+  if (!existsSync(join(rootDir, "pnpm-workspace.yaml"))) return null;
+
+  // Use pnpm ls to get all workspace packages
+  const pnpmOutput = JSON.parse(
+    execSync("pnpm ls -r --json --depth=-1", { cwd: rootDir }).toString()
+  );
+
+  // pnpm ls -r --json returns an array of workspace packages
+  // Each entry has: name, version, path, dependencies, devDependencies, etc.
+  const currentPkg = pnpmOutput.find((pkg) => {
+    return normalize(pkg.path) === normalize(workingDirectory);
+  });
+
+  if (!currentPkg) return null;
+
+  // Compute a relative location from the workspace root (matching git paths)
+  const location = relative(rootDir, currentPkg.path);
+
+  // Read the current package's package.json for dependency info
+  let pkgJson = {};
+  try {
+    pkgJson = JSON.parse(readFileSync(join(workingDirectory, "package.json"), "utf-8"));
+  } catch {}
+  const allDeps = {
+    ...(pkgJson.dependencies ?? {}),
+    ...(pkgJson.devDependencies ?? {}),
+    ...(pkgJson.peerDependencies ?? {}),
+  };
+
+  const dependantWorkspaces = pnpmOutput
+    .filter((pkg) => normalize(pkg.path) !== normalize(workingDirectory) && pkg.name in allDeps)
+    .map((pkg) => ({ location: relative(rootDir, pkg.path) }));
+
+  return { location, dependantWorkspaces };
+}
+
+function getNpmWorkspaceManifest() {
+  const workspaces = JSON.parse(execSync("npm query .workspace").toString());
+  const workingDirectory = cwd();
+  const currentWorkspace = workspaces.find((workspace) => {
+    return workspace.path.startsWith(workingDirectory);
+  });
+  if (!currentWorkspace) {
+    return null;
+  }
+  const currentWorkspaceDependencies = workspaces.filter((workspace) => {
+    return workspace.name in (currentWorkspace.dependencies ?? {}) || workspace.name in (currentWorkspace.devDependencies ?? {}) || workspace.name in (currentWorkspace.peerDependencies ?? {});
+  });
+  return {
+    location: currentWorkspace.location,
+    dependantWorkspaces: currentWorkspaceDependencies.map((currentWorkspaceDependency) => {
+      return { location: currentWorkspaceDependency.location };
+    })
+  };
+}
